# Slack App credentials — get these from https://api.slack.com/apps

# Bot OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing Secret (from Basic Information)
SLACK_SIGNING_SECRET=your-signing-secret-here

# Neon PostgreSQL connection string — get this from your Neon dashboard
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Port (3000 is fine for local; Render sets this automatically)
PORT=3000
